# App
APP_NAME=alpha-engine
ENV=development

# Database
POSTGRES_DSN=postgresql://alpha:alpha@localhost:5432/alpha_engine
REDIS_URL=redis://localhost:6379/0

# Auth
AUTH_SECRET=change-me-in-production

# ELO — Soccer
SOCCER_ELO_BASE=1500.0
SOCCER_ELO_K_BASE=32.0
SOCCER_HOME_ADV=65.0

# ELO — Tennis
TENNIS_ELO_BASE=1500.0
TENNIS_ELO_K_BASE=32.0

# ELO — Esports
ESPORTS_ELO_BASE=1500.0
ESPORTS_ELO_K_BASE=40.0

# Prediction thresholds
MIN_EDGE=0.02
MIN_ODDS=1.4
MAX_ODDS=4.0

# Monte Carlo
MC_DEFAULT_N_SIMULATIONS=10000
MC_RANDOM_SEED=42

# Live data — football-data.org (free API key, soccer)
# Sign up at https://www.football-data.org/client/register (takes 30 seconds, no CC)
FOOTBALL_DATA_API_KEY=

# Live data — The Odds API (free tier, tennis ATP/WTA + soccer odds)
# Sign up at https://the-odds-api.com/#get-access (free, no CC, 500 req/month)
TENNIS_API_KEY=

# Live data — BallDontLie GOAT (NBA real-time box scores + CS2 map/player stats)
# Register at https://app.balldontlie.io → Get API key (free tier available)
BALLDONTLIE_API_KEY=your_key_here

# Live data — Highlightly (soccer 950+ leagues, basketball, baseball, hockey)
# Register at https://highlightly.net → API key
HIGHLIGHTLY_API_KEY=your_key_here

# Scheduler (set to false to disable background data fetching)
SCHEDULER_ENABLED=true
