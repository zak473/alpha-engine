# App
APP_NAME=alpha-engine
ENV=development

# Database
POSTGRES_DSN=postgresql://alpha:alpha@localhost:5432/alpha_engine
REDIS_URL=redis://localhost:6379/0

# Auth
AUTH_SECRET=change-me-in-production

# ELO — Soccer
SOCCER_ELO_BASE=1500.0
SOCCER_ELO_K_BASE=32.0
SOCCER_HOME_ADV=65.0

# ELO — Tennis
TENNIS_ELO_BASE=1500.0
TENNIS_ELO_K_BASE=32.0

# ELO — Esports
ESPORTS_ELO_BASE=1500.0
ESPORTS_ELO_K_BASE=40.0

# Prediction thresholds
MIN_EDGE=0.02
MIN_ODDS=1.4
MAX_ODDS=4.0

# Monte Carlo
MC_DEFAULT_N_SIMULATIONS=10000
MC_RANDOM_SEED=42
